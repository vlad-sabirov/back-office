{
	"compilerOptions": {
		"target": "es5",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"baseUrl": "./src/",
		"paths": {
			"@fsd/app/*": ["fsd-app/*"],
			"@fsd/process/*": ["fsd-process/*"],
			"@fsd/pages/*": ["fsd-pages/*"],
			"@fsd/widgets/*": ["fsd-widgets/*"],
			"@fsd/features/*": ["fsd-features/*"],
			"@fsd/entities/*": ["fsd-entities/*"],
			"@fsd/shared/*": ["fsd-shared/*"],
			"@ui": ["components/UI/index.ts"],
			"@ui/*": ["components/UI/*"],
			"@globalStore": ["../pages/_app.tsx"],
			"@screens/*": ["components/screens/*"],
			"@services": ["services/index.ts"],
			"@services/*": ["services/*"],
			"@interfaces": ["interfaces/index.ts"],
			"@interfaces/*": ["interfaces/*"],
			"@components/*": ["components/*"],
			"@helpers": ["helpers/index.ts"],
			"@helpers/*": ["helpers/*"],
			"@hooks": ["hooks/index.ts"],
			"@hooks/*": ["hooks/*"],
			"@public/*": ["../public/*"],
			"@config/*": ["../config/*"],
			"@layouts/*": ["layouts/*"],
			"@src/*": ["./*"]
		}
	},
	"include": ["dts/next-env.d.ts", "dts/images.d.ts", "**/*.ts", "**/*.tsx", "config/**/*.[jt]s", "*.config.js", "src/fsd-shared/ui/table-transform/user/User"],
	"exclude": ["node_modules", ".vscode"]
}
