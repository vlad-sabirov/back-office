        "/ping": {
            "get": {
                "description": "Простой пинг-понг для проверки доступности сервиса",
                "consumes": [
                    "text/plain"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "ping"
                ],
                "summary": "Проверка доступности сервиса",
                "responses": {
                    "200": {
                        "description": "pong",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error"
                    }
                }
            }
        },
        "/task": {
            "post": {
                "description": "Принимает данные задачи и создает новую задачу",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "Создание новой задачи",
                "parameters": [
                    {
                        "description": "DTO для создания задачи",
                        "name": "task",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.CreateTaskRequestV1"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Успешное создание задачи",
                        "schema": {
                            "$ref": "#/definitions/api.CreateTaskResponseV1"
                        }
                    },
                    "400": {
                        "description": "Какая-то ошибка",
                        "schema": {
                            "$ref": "#/definitions/api.CreateTaskResponseV1"
                        }
                    }
                }
            }
        },
